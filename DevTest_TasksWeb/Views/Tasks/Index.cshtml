@model IEnumerable<DevTest_TasksWeb.Models.Tasks>

@{
    ViewData["Title"] = "Tasks List";
}
<div class="row">
    <div class="col"><h3>Tasks List</h3></div>
    <div class="col-auto"><a asp-action="Create" class="btn btn-primary">Create New</a></div>
</div>


<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th style="width:50px">
                @Html.DisplayNameFor(model => model.Task_Status)
            </th>
            <th style="width:170px">
                @Html.DisplayNameFor(model => model.DueAt)
            </th>
            <th style="width:240px"></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                    @Html.DisplayFor(modelItem => item.Task_Status) 
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DueAt)
            </td>
            <td>
                <a class="btn btn-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a class="btn btn-primary" asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a class="btn btn-primary" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
